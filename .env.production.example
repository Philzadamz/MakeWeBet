# Copy to .env.production and fill in. NEVER commit the real file.
NODE_ENV=production
PORT=4000
API_GLOBAL_PREFIX=api

POSTGRES_USER=fiq
POSTGRES_PASSWORD=
POSTGRES_DB=fiq
DATABASE_URL=postgresql://fiq:${POSTGRES_PASSWORD}@postgres:5432/fiq?schema=public

REDIS_URL=redis://redis:6379

JWT_ACCESS_SECRET=
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=2592000

CORS_ORIGINS=https://app.yourdomain.com
APP_URL=https://app.yourdomain.com

PAYMENT_PRIMARY_PROVIDER=PAYSTACK
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=

SPORTS_PRIMARY_PROVIDER=API_FOOTBALL
API_FOOTBALL_KEY=

# 32-byte hex: openssl rand -hex 32
PII_ENCRYPTION_KEY=
